{
  "manifest_version": 3,
  "name": "ConfuSense",
  "version": "9.0.0",
  "description": "Real-time Gemini-powered confusion detection for Google Meet",

  "icons": {
    "16":  "assets/icons/icon16.png",
    "32":  "assets/icons/icon32.png",
    "48":  "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },

  "permissions": [
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:3000/*"
  ],

  "background": {
    "service_worker": "background.js",
